# System CLI (not a Docker image) — minimum tested version
NGROK_MIN_VERSION=3.39.6

# Container names (must match start_saulie.sh)
BGE_CONTAINER=tensorrt_bge-m3
QDRANT_CONTAINER=qdrant_index
VLLM_CONTAINER=eval_deploy_qwenie
