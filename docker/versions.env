# Pinned Docker images for the Saulie stack.
# Sourced by deploy scripts and docker/setup_containers.sh.
# Update digests after: docker inspect <container> --format '{{.Config.Image}}'
#
# Captured from working environment on 2026-06-11.

BGE_IMAGE=nvcr.io/nvidia/tensorrt:24.12-py3
QDRANT_IMAGE=qdrant/qdrant@sha256:0fb8897412abc81d1c0430a899b9a81eb8328aa634e7242d1bc804c1fe8fe863
