# Saulie environment template
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# start_saulie.sh sources .env automatically if present.

# --- Secrets (required for public access) ---
NGROK_KEY=
NGINX_API_KEY=change-me
VLLM_API_KEY=change-me
LLM_API_KEY=change-me

# --- Paths ---
SAULIE_REPO=/root/saulie
RAG_ROOT=/root/rag
SAULIE_PYTHON=/root/miniconda3/envs/saulgman/bin/python

# --- Production defaults ---
SAULIE_MODEL=dpo-v15-trial-4
SAULIE_PROMPT=compressed
SAULIE_DEPLOY_SCRIPT=/root/saulie/dpo/eval/vllm_scripts/deploy_finalist_pick.sh

# --- Service ports ---
AGENT_PORT=9000
VLLM_PORT=8000
NGINX_PORT=8080
EMBED_PORT=8888
QDRANT_PORT=1234

# --- RAG ---
QDRANT_COLLECTION=amazon_products_v2
FUSION_METHOD=rrf
EMBED_URL=http://localhost:8888/embed
QDRANT_URL=http://localhost:1234
PREFETCH_LIMIT=50

# --- Agent / vLLM client ---
LLM_BASE_URL=http://localhost:8000/v1
MODEL_NAME=dpo-v15-trial-4
PORT=9000

# --- Remote client (remote_chat.py) ---
PUBLIC_URL=https://your-ngrok-url.ngrok-free.dev

# --- RAG data prep (optional, for indexing) ---
# MCCAULEY_META_DIR=/root/rag/mccauley_meta
# MCCAULEY_CSV=/root/rag/mccauley_products_500k.csv
# INDIAN_CSV_IN=/root/rag/Amazon-Products_fixed_deduped.csv
# INDIAN_CSV_OUT=/root/rag/amazon_indian_clean.csv

# --- DPO training (optional) ---
# DPO_MAX_VAL_DIAG_WALL_S=600
# DPO_MAX_STEP_WALL_S=120
# MLFLOW_TRACKING_URI=file:///root/saulie/dpo/train/mlruns
# MLFLOW_EXPERIMENT_NAME=steering-dpo
