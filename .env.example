# Saulie environment template
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# start_saulie.sh sources .env automatically if present.

# --- Secrets (required for public access) ---
NGROK_KEY=
NGINX_API_KEY=secret
VLLM_API_KEY=dipshit
LLM_API_KEY=dipshit
# WSL2/Docker Desktop: use 0.0.0.0 if 127.0.0.1:8000 bind fails
# VLLM_BIND=0.0.0.0

# --- Paths ---
SAULIE_REPO=/root/saulie
RAG_ROOT=/root/saulie/rag
SAULIE_PYTHON=/root/miniconda3/envs/saulgman/bin/python

# --- Production defaults ---
SAULIE_MODEL=dpo-v15-trial-4
SAULIE_PROMPT=compressed
SAULIE_DEPLOY_SCRIPT=/root/saulie/dpo/eval/vllm_scripts/deploy_finalist_pick.sh

# --- Service ports ---
AGENT_PORT=9000
VLLM_PORT=8000
NGINX_PORT=8080
EMBED_PORT=8888
QDRANT_PORT=1234

# --- RAG ---
QDRANT_COLLECTION=amazon_products_v2
FUSION_METHOD=rrf
EMBED_URL=http://localhost:8888/embed
QDRANT_URL=http://localhost:1234
PREFETCH_LIMIT=50
# Relevance gate: RRF still RANKS (good for short product titles); dense COSINE gates relevance.
# Calibrate with rag/calibrate_cosine_threshold.py, A/B with rag/retrieval_ab_eval.py.
#   > 0  -> gate ON: RRF order, cosine >= MIN, capped at MAX; 0 above => "no relevant products"
#   <= 0 -> gate OFF: pure RRF baseline, top MAX by fused rank (use 0 for the A/B baseline)
SAULIE_RAG_MIN_COSINE=0.5
SAULIE_RAG_MAX_RESULTS=5

# --- Agent / vLLM client ---
LLM_BASE_URL=http://localhost:8000/v1
MODEL_NAME=dpo-v15-trial-4
PORT=9000

# --- Tool pressure harness (custom vLLM logits processor) ---
# Requires vLLM deploy with --logits-processors (deploy_finalist_pick.sh)
SAULIE_TOOL_PRESSURE_ENABLED=1
SAULIE_TOOL_PRESSURE_BACKEND=processor
SAULIE_TOOL_BIAS_START_TURN=3
SAULIE_TOOL_FORCE_TURN=6
# Absolute logit add per effective turn. Keep SMALL: 8 -> +24/+32/+40 saturated and silently
# forced. 2 -> +6/+8/+10 is a real nudge. Try 2, drop to 1 if turn 3 still always searches.
SAULIE_TOOL_BIAS_PER_TURN=2
SAULIE_TOOL_PRESSURE_MOD=0
SAULIE_TOOL_FORCE_MODE=off
# Bounded LRU for the server-side tool-aware pressure reset (fingerprint -> last search turn).
SAULIE_TOOL_PRESSURE_REGISTRY_MAX=512

# --- Remote client (remote_chat.py) ---
PUBLIC_URL=https://your-ngrok-url.ngrok-free.dev

# --- RAG data prep (optional, for indexing) ---
# MCCAULEY_META_DIR=/root/saulie/rag/mccauley_meta
# MCCAULEY_CSV=/root/saulie/rag/mccauley_products_500k.csv
# INDIAN_CSV_IN=/root/saulie/rag/Amazon-Products_fixed_deduped.csv
# INDIAN_CSV_OUT=/root/saulie/rag/amazon_indian_clean.csv

# --- DPO training (optional) ---
# DPO_MAX_VAL_DIAG_WALL_S=600
# DPO_MAX_STEP_WALL_S=120
# MLFLOW_TRACKING_URI=file:///root/saulie/dpo/train/mlruns
# MLFLOW_EXPERIMENT_NAME=steering-dpo
